@"
# Dependencies - DO NOT COMMIT
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
*.local

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files (passwords, keys)
.env
.env.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Temporary data
server/logs/
data/temp/
"@ | Out-File -FilePath .gitignore -Encoding utf8